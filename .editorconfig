root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[Caddyfile]
indent_style = tab
end_of_line = lf

[*.{env,sh}]
end_of_line = lf

[*.md]
trim_trailing_whitespace = false

[*.secret]
end_of_line = lf
insert_final_newline = false

[*.yaml]
indent_size = 2
